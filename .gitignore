# ROS 2 colcon workspace build artifacts — regenerated by `colcon build`,
# never commit these. If they're already tracked, see the note at the bottom.
/build/
/install/
/log/

# Per-package build artifacts, in case colcon is ever run from inside a
# package folder instead of the workspace root.
build/
install/
log/

# Python
__pycache__/
*.pyc

# Stonefish source, if someone clones it into the repo instead of /tmp while
# following the install instructions in the README.
/stonefish/

# Editors / OS noise
.vscode/
*.swp
.DS_Store
